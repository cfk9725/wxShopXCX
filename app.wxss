/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  padding: 20rpx;
}

/* 价格样式 */
.price {
  color: #1e90ff;
  font-weight: bold;
}

.old-price {
  color: #999;
  text-decoration: line-through;
  font-size: 24rpx;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #1e90ff, #00bfff);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

/* 加载中样式 */
.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

/* 轮播图图片 */
.banner-img {
  width: 100%;
  height: 100%;
}

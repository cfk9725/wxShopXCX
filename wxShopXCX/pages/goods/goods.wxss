/* 商品大图 */
.goods-header {
  background: #fff;
}

.goods-big-img {
  height: 600rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 200rpx;
  background: #fafafa;
}

/* 价格区 */
.price-section {
  background: #fff;
  padding: 24rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.current-price {
  font-size: 48rpx;
  color: #1e90ff;
  font-weight: bold;
}

.origin-price {
  font-size: 28rpx;
  color: #999;
  text-decoration: line-through;
}

.discount-tag {
  background: linear-gradient(135deg, #1e90ff, #00bfff);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.sales {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 名称区 */
.name-section {
  background: #fff;
  padding: 0 24rpx 24rpx;
  margin-bottom: 20rpx;
}

.goods-title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.goods-subtitle {
  font-size: 26rpx;
  color: #666;
}

/* 商品参数 */
.info-section {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.info-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.info-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  width: 120rpx;
  color: #999;
  font-size: 26rpx;
}

.info-value {
  flex: 1;
  color: #333;
  font-size: 26rpx;
}

/* 图文详情 */
.detail-section {
  background: #fff;
  padding: 24rpx;
}

.detail-content {
  padding-top: 10rpx;
}

.detail-block {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.detail-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.detail-img {
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 150rpx;
  background: #fafafa;
  border-radius: 16rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.08);
  padding: 0 24rpx;
  gap: 20rpx;
}

.bar-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100rpx;
}

.bar-icon-text {
  font-size: 40rpx;
}

.bar-icon-label {
  font-size: 20rpx;
  color: #666;
}

.bar-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}

.add-cart {
  background: #00bfff;
  color: #fff;
}

.buy-now {
  background: linear-gradient(135deg, #1e90ff, #00bfff);
  color: #fff;
}

/* 空购物车 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  gap: 24rpx;
}

.empty-icon {
  font-size: 120rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
}

.go-shopping {
  background: linear-gradient(135deg, #1e90ff, #00bfff);
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 60rpx;
  border-radius: 40rpx;
}

/* 购物车列表 */
.cart-list {
  padding: 20rpx 24rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  gap: 20rpx;
}

/* 选择框 */
.check-box {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.check-box.checked {
  background: #1e90ff;
  border-color: #1e90ff;
}

.check-icon {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

/* 商品图片 */
.cart-goods-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #fafafa;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  flex-shrink: 0;
}

/* 商品信息 */
.cart-goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 140rpx;
}

.cart-goods-name {
  font-size: 28rpx;
  color: #333;
}

.cart-goods-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 数量控制 */
.quantity-control {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.qty-btn {
  width: 48rpx;
  height: 48rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666;
}

.qty-num {
  font-size: 28rpx;
  color: #333;
  min-width: 40rpx;
  text-align: center;
}

/* 底部结算栏 */
.checkout-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.08);
  gap: 16rpx;
}

.check-all-box {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-all-box.checked {
  background: #1e90ff;
  border-color: #1e90ff;
}

.check-all-text {
  font-size: 28rpx;
  color: #333;
}

.total-section {
  flex: 1;
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  margin-right: 20rpx;
}

.total-label {
  font-size: 28rpx;
  color: #333;
}

.total-price {
  font-size: 36rpx;
  color: #1e90ff;
  font-weight: bold;
}

.checkout-btn {
  background: linear-gradient(135deg, #1e90ff, #00bfff);
  color: #fff;
  font-size: 30rpx;
  padding: 18rpx 50rpx;
  border-radius: 44rpx;
}

<!-- 个人中心页 -->
<view class="page">
  <!-- 用户信息区 -->
  <view class="user-header">
    <!-- 已登录：显示头像 + 昵称 -->
    <block wx:if="{{userInfo && isLoggedIn}}">
      <view class="avatar">
        <image class="avatar-img" src="{{userImg}}" mode="aspectFill"></image>
      </view>
      <view class="user-info">
        <text class="username">{{userInfo.nick_name}}</text>
        <block wx:if="{{!userInfo.OpenId}}">
          <text class="user-tip" bindtap="onBindingWx">点击绑定微信账号</text>
        </block>
        <block wx:else>
          <text class="user-tip">已绑定微信账号</text>
        </block>
      </view>
      <view class="logout-btn" bindtap="onLogout">退出</view>
    </block>

    <!-- 未登录状态 -->
    <block wx:else>
      <button class="avatar-btn">
        <image class="avatar avatar-placeholder" src="{{userImg}}"></image>
      </button>
      <view class="user-info">
        <text class="username" bindtap="onLoginTap">点击登录</text>
        <text class="user-tip">登录后享受更多权益</text>
      </view>
    </block>
  </view>

  <!-- 订单状态 -->
  <view class="order-section">
    <view class="section-head">
      <text class="section-label">我的订单</text>
      <text class="section-more">查看全部 ></text>
    </view>
    <view class="order-status">
      <view class="status-item" wx:for="{{orderStatus}}" wx:key="key" bindtap="onOrderTap" data-key="{{item.key}}">
        <text class="status-icon">{{item.icon}}</text>
        <text class="status-text">{{item.text}}</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="func-section">
    <view class="func-item" wx:for="{{funcList}}" bindtap="onFuncTap" data-key="{{item.key}}">
      <view class="func-left">
        <text class="func-icon">{{item.icon}}</text>
        <text class="func-text">{{item.text}}</text>
      </view>
      <text class="func-arrow">></text>
    </view>
  </view>
</view>

<!-- 弹出层注册 start -->
<view 
  class="popup-mask register-popup {{showPopup ? 'show' : ''}}" 
  bindtap="hideRegisterPopup"
></view>

<view class="popup-panel {{showPopup ? 'show' : ''}}">
  <view class="popup-header">
    <text>注册</text>
    <text class="close" bindtap="hideRegisterPopup">✕</text>
  </view>

  <view class="popup-body">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="avatar avatar-placeholder" src="{{userImg}}"></image>
    </button>
    <!-- 微信昵称输入框 -->
    <input
      class="zcInputCtl nickname-input"
      type="nickname"
      placeholder="请输入昵称*"
      value="{{nickName}}"
      bindinput="onNickNameInput"
    />
    <input
      class="zcInputCtl phonenumber-input"
      placeholder="请输入手机号"
      value="{{phoneNumber}}"
      bindinput="onPhoneNumberInput"
    />
  </view>

  <view class="popup-footer">
    <button type="primary" bindtap="onRegisterConfirm">确定</button>
  </view>
</view>
<!-- 弹出层注册 end -->

<!-- 弹出层登录 start -->
<view 
  class="popup-mask login-popup {{showLoginPopup ? 'show' : ''}}" 
  bindtap="hideLoginPopup"
></view>

<view class="popup-panel {{showLoginPopup ? 'show' : ''}}">
  <view class="popup-header">
    <text>登录</text>
    <text class="close" bindtap="hideLoginPopup">✕</text>
  </view>

  <view class="popup-body">
    <input
      class="zcInputCtl username-input"
      placeholder="请输入账户*"
      value="{{username}}"
      bindinput="onUserNameInput"
    />
    <input
      class="zcInputCtl userpwd-input"
      password
      placeholder="请输入密码*"
      value="{{phoneNumber}}"
      bindinput="onUserPwdInput"
    />
    <button type="primary" class="loginConfirm" bindtap="onLoginConfirm">确定</button>
  </view>

  <view class="popup-footer">
    <button open-type="primary" class="avatar-btn" bindtap="onWxLoginConfirm">
      <image class="avatar avatar-placeholder" src="{{wxImg}}"></image>
    </button>
  </view>
</view>
<!-- 弹出层登录 end -->

<!-- 弹出层收货地址 start -->
<view 
  class="popup-mask shDz-popup {{showShDzPopup ? 'show' : ''}}" 
  bindtap="hideShDzPopup"
></view>

<view class="popup-panel shDz-panel {{showShDzPopup ? 'show' : ''}}">
  <view class="popup-header">
    <text>收货地址管理</text>
    <text class="close" bindtap="hideShDzPopup">✕</text>
  </view>

  <view class="popup-tools">
    <button type="primary" bindtap="onBtnAddShDz">新增</button>
  </view>

  <view class="popup-body">
    <scroll-view scroll-y class="shDzScroll">
      <view wx:for="{{shDzlist}}" wx:key="id" bindtap="onMapSelect" data-item="{{item}}">
        <view class="mapItem">
          <view class="mapItemTitle">{{item.is_default == 1 ? "默认 - " : ""}}{{item.recipient_name}} - {{item.mobile}}</view>
          <view class="mapItemAddress">{{item.street}}</view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
<!-- 弹出层收货地址 end -->

<!-- 弹出层收货地址设置 start -->
<view 
  class="popup-mask shDzSz-popup {{showShDzSzPopup ? 'show' : ''}}" 
  bindtap="hideShDzSzPopup"
></view>

<view class="popup-panel shDzSz-panel {{showShDzSzPopup ? 'show' : ''}}">
  <view class="popup-header">
    <text>收货地址设置</text>
    <text class="close" bindtap="hideShDzSzPopup">✕</text>
  </view>

  <view class="popup-body">
    <scroll-view scroll-y>
      <view class="search-bar">
        <input class="zcInputCtl mapInput" placeholder="搜索地点，如：咖啡店" value="{{keyword}}" bindinput="onMapInput" bindconfirm="onMapSearch" />
      </view>

      <map
        id="myMap"
        longitude="{{longitude}}"
        latitude="{{latitude}}"
        scale="16"
        markers="{{markers}}"
        style="width:100%;height:30vh;"
        bindtap="onMapTap"
      ></map>

      <scroll-view scroll-y class="mapResult">
        <view wx:for="{{maplist}}" wx:key="id" bindtap="onMapSelect" data-item="{{item}}">
          <view class="mapItem">
            <view class="mapItemTitle">{{item.title}}</view>
            <view class="mapItemAddress">{{item.address}}</view>
          </view>
        </view>
      </scroll-view>      
      <input class="zcInputCtl mapInputCtl" placeholder="收件人姓名" value="{{sjrRecipientName}}" />   
      <input class="zcInputCtl mapInputCtl" placeholder="收件人手机号" value="{{sjrMobile}}" />   
      <input class="zcInputCtl mapInputCtl" placeholder="详细地址" value="{{sjrStreet}}" />   
      <input class="zcInputCtl mapInputCtl" placeholder="邮政编码" value="{{sjrPostalCode}}" />
      <checkbox-group class="mapInputCtl" bindchange="onIsDefaultChange">        
        是否默认地址：<checkbox value="1" checked="{{sjrIsDefault}}"/>
      </checkbox-group>    
      <button type="primary" class="mapInputCtl" bindtap="onBtnSaveShDzSz">保存</button>
    </scroll-view>
  </view>
</view>
<!-- 弹出层收货地址设置 end -->

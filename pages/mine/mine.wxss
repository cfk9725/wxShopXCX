/* 用户信息区 */
.user-header {
  background: linear-gradient(135deg, #1e90ff, #00bfff);
  padding: 60rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #fff;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.avatar-placeholder {
  background: rgba(255, 255, 255, 0.3);
}

.avatar-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.username {
  font-size: 34rpx;
  color: #fff;
  font-weight: bold;
}

.user-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 订单状态 */
.order-section {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  display: flex;
  justify-content: space-around;
}

.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.status-icon {
  font-size: 44rpx;
}

.status-text {
  font-size: 24rpx;
  color: #666;
}

/* 功能列表 */
.func-section {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.func-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.func-item:last-child {
  border-bottom: none;
}

.func-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.func-icon {
  font-size: 36rpx;
}

.func-text {
  font-size: 28rpx;
  color: #333;
}

.func-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 退出登录按钮 */
.logout-btn {
  margin-left: auto;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 30rpx;
  flex-shrink: 0;
}

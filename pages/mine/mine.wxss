wx-button[type=primary] {
  background-color: #1e90ff;
}

/* 用户信息区 */
.user-header {
  background: linear-gradient(135deg, #1e90ff, #00bfff);
  padding: 60rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #fff;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.avatar-placeholder {
  background: rgba(255, 255, 255, 0.3);
}

.avatar-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.username {
  font-size: 34rpx;
  color: #fff;
  font-weight: bold;
}

.user-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 订单状态 */
.order-section {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  display: flex;
  justify-content: space-around;
}

.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.status-icon {
  font-size: 44rpx;
}

.status-text {
  font-size: 24rpx;
  color: #666;
}

/* 功能列表 */
.func-section {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.func-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.func-item:last-child {
  border-bottom: none;
}

.func-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.func-icon {
  font-size: 36rpx;
}

.func-text {
  font-size: 28rpx;
  color: #333;
}

.func-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 退出登录按钮 */
.logout-btn {
  margin-left: auto;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 30rpx;
  flex-shrink: 0;
}

/* 蒙层 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 999;
}

.popup-mask.show {
  opacity: 1;
  visibility: visible;
}

/* 底部面板 */
.popup-panel {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 1000;
  /* padding-bottom: env(safe-area-inset-bottom); */
}

.popup-panel.show {
  transform: translateY(0);
}

/* 内部样式 */
.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  font-size: 32rpx;
  font-weight: 500;
  border-bottom: 1rpx solid #eee;
}

.close {
  color: #999;
}

.popup-body {
  padding: 32rpx;
  padding-bottom: 0;
}

.zcInputCtl {
  height: 80rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 0 20rpx;
}

.zcInputCtl + .zcInputCtl {
  margin-top: 20rpx;
}

.popup-footer {
  padding: 32rpx;
}

.popup-body .avatar-btn {
  width: 120rpx;
  margin-bottom: 20rpx;
}

.loginConfirm {  
  margin-top: 30rpx;
}

.popup-footer .avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #fff;
  overflow: hidden;
}

.popup-footer .avatar-btn {
  width: 60rpx;
  margin-bottom: 15rpx;
}

.popup-tools {
  text-align: right;
  border-bottom: 1rpx solid #eee;
  padding: 5px 0;
}

.popup-tools wx-button[type=primary] {
    display: inline-block;
    width: 60px;
    padding-left: 5px;
    padding-right: 5px;
    margin-top: 0;
    margin-right: 5px;
}

.popup-tools wx-button[type=primary]:hover {
  background-color: #00bfff;
}

.shDzSz-panel {
  height: 80%;
}

.shDzSz-panel > .popup-body {
  position: absolute;
  top: 55px;
  right: 0;
  bottom: 0;
  left: 0;
  padding-bottom: 5px;
}

.shDzSz-panel > .popup-body > scroll-view {
  height: 100%;
}

.mapInput {
  margin-bottom: 5px;
}

.mapResult {
  /* height: 100px; */
  max-height: 100px;
  margin-top: 5px;
  border: 1px solid #eee;
}

.mapItem {
  padding: 5px;
  background-color: #eee;
  border: 1px solid #fff;
}

.mapItem .mapItemTitle {
  font-size: 18px;
}

.mapItem .mapItemAddress {
  font-size: 12px;
  padding-left: 10px;
}

.mapInputCtl {
  margin-top: 5px;
}

.shDz-panel .popup-body {
  padding-top: 5px;
}

.shDzScroll {
  height: 200px;
}


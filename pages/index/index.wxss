/* 搜索栏 */
.search-bar {
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #1e90ff, #00bfff);
}

.search-input {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  background: #fff;
  border-radius: 32rpx;
  gap: 8rpx;
}

.search-icon {
  font-size: 28rpx;
}

.search-placeholder {
  color: #999;
  font-size: 26rpx;
}

/* 轮播图 */
.banner {
  height: 300rpx;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-item {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
}

.banner1 {
  background: linear-gradient(135deg, #1e90ff, #00bfff);
}

.banner2 {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.banner3 {
  background: linear-gradient(135deg, #11998e, #38ef7d);
}

.banner-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.banner-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 分类导航 */
.category-section {
  display: flex;
  flex-wrap: wrap;
  background: #fff;
  margin: 0 24rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx 0;
}

.category-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #e6f4ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 24rpx;
  color: #666;
}

/* 推荐标题 */
.section-title {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  gap: 20rpx;
}

.title-line {
  width: 60rpx;
  height: 2rpx;
  background: #ddd;
}

.title-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

/* 商品列表 */
.goods-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 0 24rpx;
}

.goods-card {
  width: 340rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.goods-img {
  height: 260rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 100rpx;
  background: #fafafa;
}

.goods-info {
  padding: 16rpx;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.goods-desc {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.goods-price-wrap {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.add-cart-btn {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #1e90ff, #00bfff);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  line-height: 44rpx;
}

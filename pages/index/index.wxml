<!-- 首页 -->
<view class="page">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input" bindtap="onSearchTap">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索商品</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>
    <!-- 轮播图 -->
    <swiper class="banner" indicator-dots autoplay circular interval="3000" duration="500">
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <image class="banner-img" src="{{item.imageUrl}}" mode="aspectFill"></image>
      </swiper-item>
    </swiper>

    <!-- 分类导航 -->
    <view class="category-section">
      <view class="category-item" wx:for="{{categories}}" wx:key="id" bindtap="onCategoryTap" data-id="{{item.id}}">
        <view class="category-icon">{{item.icon}}</view>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>

    <!-- 热门推荐标题 -->
    <view class="section-title">
      <view class="title-line"></view>
      <text class="title-text">热门推荐</text>
      <view class="title-line"></view>
    </view>

    <!-- 商品列表 -->
    <view class="goods-list">
      <view class="goods-card" wx:for="{{goodsList}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
        <view class="goods-img">{{item.img}}</view>
        <view class="goods-info">
          <text class="goods-name">{{item.name}}</text>
          <text class="goods-desc">{{item.desc}}</text>
          <view class="goods-bottom">
            <view class="goods-price-wrap">
              <text class="price">¥{{item.price}}</text>
              <text class="old-price">¥{{item.oldPrice}}</text>
            </view>
            <view class="add-cart-btn" catchtap="onAddCart" data-id="{{item.id}}">+</view>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
